# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose environment template
# Copy this file to .env and fill in all "replace-me" values before starting.
#
#   cp .env.docker.example .env
#
# NEVER commit the filled-in .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dora
POSTGRES_PASSWORD=replace-me-db-password
POSTGRES_DB=dora_metrics

# DATABASE_URL is derived from the above by docker-compose.yml automatically.
# Override only if you use an external Postgres instance:
# DATABASE_URL=postgresql+psycopg2://dora:replace-me@db:5432/dora_metrics

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_BASE_URL=https://gitlab.plunet.com
GITLAB_API_TOKEN=replace-me
# Optional: comma-separated override. If unset, docker-compose mounts ./configuration.yml (DORA_CONFIG_PATH) for project_paths and other YAML defaults.
# GITLAB_PROJECT_PATHS=operations/dora-metrics,group/other-project

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://plunet.atlassian.net
JIRA_USER_EMAIL=replace-me@example.com
JIRA_API_TOKEN=replace-me

# ── Admin bootstrap ───────────────────────────────────────────────────────────
DORA_ADMIN_USERNAME=admin
DORA_ADMIN_PASSWORD=replace-me

# Signed session cookie secret (min. 16 characters, generate a random string)
DORA_SESSION_SECRET=replace-with-a-long-random-secret

# App-level encryption key for persisted secrets stored in the DB (32 bytes)
CONFIG_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the public URL Caddy serves the frontend on, e.g.:
#   DORA_CORS_ORIGINS=https://dora.example.com
# For localhost testing:
DORA_CORS_ORIGINS=http://localhost:3000

# ── Frontend API URL ──────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time.
# Set to the public-facing Caddy URL for the backend /api endpoint, e.g.:
#   NEXT_PUBLIC_API_URL=https://dora.example.com/api
# For localhost testing:
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Port overrides (optional) ─────────────────────────────────────────────────
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# ── Environment mode ──────────────────────────────────────────────────────────
# Set to "production" to enforce HTTPS-only session cookies
DORA_ENVIRONMENT=production
